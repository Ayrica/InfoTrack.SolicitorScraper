@page "/"

<PageTitle>Dashboard</PageTitle>

<div class="page-header">
    <h1>Dashboard</h1>
    <p class="page-subtitle">
        Extract conveyancing solicitor contact details by location for the InfoTrack sales team.
    </p>
</div>

<section class="card">
    <h2>Getting started</h2>
    <ol class="steps-list">
        <li>Review and adjust your <NavLink href="/locations">locations list</NavLink>.</li>
        <li>On the Locations page, click <strong>Save</strong> to persist changes or <strong>Scrape</strong> to fetch solicitor data.</li>
        <li>Browse <NavLink href="/solicitors">solicitors</NavLink> and view the <NavLink href="/report">summary report</NavLink>.</li>
    </ol>
</section>

<section class="card-grid">
    <article class="card card-link">
        <h2><NavLink href="/locations">Locations</NavLink></h2>
        <p>Add, remove, save, and scrape cities used for solicitor data.</p>
    </article>
    <article class="card card-link">
        <h2><NavLink href="/solicitors">Solicitors</NavLink></h2>
        <p>Browse scraped contact details and filter by location.</p>
    </article>
    <article class="card card-link">
        <h2><NavLink href="/report">Report</NavLink></h2>
        <p>Executive summary and top prospects by review count.</p>
    </article>
</section>
